# ============================================
# Vault Strategy Bot — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   chmod 600 .env

# --- Perp Exchange ---
# "binance" (default) or "drift" (Solana DEX, no KYC required)
# When set to "drift", BINANCE_API_KEY/SECRET are not required
PERP_EXCHANGE=binance

# --- Binance Futures (required when PERP_EXCHANGE=binance) ---
# API key with Futures trading permission ONLY (no withdrawal)
# Restrict to VPS IP address in Binance API settings
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Solana ---
# Helius RPC endpoint (includes API key in URL)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Wallet keypair (base58-encoded 64-byte Ed25519 keypair)
SOLANA_PRIVATE_KEY=
SOLANA_WALLET_ADDRESS=

# --- Telegram Alerts (recommended) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- API Server Auth (recommended) ---
# Bearer token to protect the monitoring dashboard
# Generate with: openssl rand -hex 32
API_AUTH_TOKEN=

# --- Jupiter API ---
# API key for Jupiter Price API (free tier at https://portal.jup.ag)
JUPITER_API_KEY=

# --- Runtime ---
NODE_ENV=production
LOG_LEVEL=info
