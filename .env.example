# ============================================
# Vault — Environment Variables
# ============================================
# bot, frontend, scripts 全��がこのファイルを参���
# リモートでもローカルでもこの1���ァイルで管理
#
# cp .env.example .env && chmod 600 .env

# --- Anthropic API (AI Advisor) ---
# 取得元: https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY=

# --- Bot API (frontend proxy & advisorテスト用) ---
BOT_API_URL=http://localhost:3000
BOT_API_TOKEN=

# --- Perp Exchange ---
PERP_EXCHANGE=binance
DRIFT_NETWORK=mainnet-beta

# --- Binance Futures ---
# API key with Futures trading permission ONLY (no withdrawal)
# Restrict to VPS IP address in Binance API settings
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_USDC_DEPOSIT_ADDRESS=

# --- Solana ---
# Helius RPC endpoint (includes API key in URL)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Wallet keypair (base58-encoded 64-byte Ed25519 keypair)
SOLANA_PRIVATE_KEY=
SOLANA_WALLET_ADDRESS=

# --- Telegram Alerts ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- API Server Auth ---
# Generate with: openssl rand -hex 32
API_AUTH_TOKEN=

# --- Jupiter API ---
# Free tier at https://portal.jup.ag
JUPITER_API_KEY=

# --- Runtime ---
NODE_ENV=production
API_PORT=3000
LOG_LEVEL=info
